# =============================================================================
# .gitignore for the Spindle-TI public repository
# =============================================================================

# ----- Large pre-computed time-frequency data (external archive) -------------
3_FIGURE2_Power/TFR_1HzSmoothing/
3_FIGURE2_Power/TFR/

# ----- Large headline results stored in external archive --------------------
# Too large for GitHub; distributed via the data archive alongside data/.
1_eventDetection/eventDetectionResults/all_slowwaves.mat

# ----- Generated figures (regenerated by figure scripts) ---------------------
*.png
*.svg
*.fig
*.docx
*.RData

# ----- Generated per-figure outputs (regenerable; large data lives in archive) -
# All .mat / .txt under any outputs/ folder are treated as regenerable.
# Curated headline results (e.g. 1_eventDetection/eventDetectionResults/) are
# NOT under outputs/ and remain tracked.
# Input/config txts (requirements.txt, correctElectrodeOrder.txt, Sleep profile
# / Markers scoring exports under SleepStagingAndEvents/) are intentionally
# tracked because they live outside outputs/.
**/outputs/*.mat
**/outputs/*.csv
**/outputs/*.txt
preprocessing_rejection_statistics.txt

# ----- Regenerable caches outside cache/ folders -----------------------------
1_eventDetection/eventDetectionResults/sleep_stage_trial_cache.mat

# ----- Cache directories (any 'cache/' folder anywhere) ----------------------
**/cache/

# ----- Raw / processed data (in-repo, downloaded from external archive) ------
# Scripts resolve all data files under <repo>/data/{analysis,EDF,COMPLETE,...}.
# Place downloaded files there; the folder is never committed.
/data/
/toolboxes/
*.xdf
*.edf

# ----- Editor / IDE / agent local config -------------------------------------
.vscode/
.idea/

# ----- MATLAB transient files ------------------------------------------------
*.asv
*.m~
*.mex*
slprj/

# ----- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/

# ----- R ---------------------------------------------------------------------
.Rhistory
.Rproj.user/

# ----- OS junk ---------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
